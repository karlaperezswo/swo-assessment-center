# ============================================
# CONFIGURACIÓN LOCAL - ASSESSMENT CENTER
# ============================================

NODE_ENV=development
PORT=4000

# ============================================
# AWS - REGIÓN Y BUCKET S3
# ============================================
AWS_REGION=us-east-1
S3_BUCKET_NAME=assessment-center-files-tunombre

# ============================================
# CREDENCIALES AWS
# ============================================
# El servidor resuelve credenciales en este orden:
#
# 1. Variables de entorno (descomenta si las tienes):
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=wJalr...
#
# 2. Perfil AWS CLI (recomendado para desarrollo local):
#    Ejecuta: aws configure
#    Luego el SDK usa automáticamente ~/.aws/credentials
#
# 3. IAM Role (producción - Lambda/EC2):
#    Asigna un rol con permisos s3:* y bedrock:InvokeModel
#    No se necesita ninguna variable de entorno adicional.
#
# Si ves errores de tipo "InvalidAccessKeyId" o "AccessDenied",
# revisa los logs del servidor — se mostrará exactamente qué falta.

# ============================================
# BEDROCK (IA)
# ============================================
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_TIMEOUT_MS=300000
BEDROCK_MAX_RETRIES=3
