# Local Development
NODE_ENV=development
PORT=4000

# AWS Configuration (solo para producción/Lambda)
# Estas variables se configuran automáticamente en Lambda
# Solo necesitas configurarlas si pruebas S3 localmente

# AWS_REGION=us-east-1
# S3_BUCKET_NAME=assessment-center-files-tunombre
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# AWS Bedrock Configuration
# Estas variables controlan el comportamiento del servicio de IA
# En desarrollo local, usa las credenciales de tu perfil de AWS CLI
# En producción (Lambda), usa el IAM Role automáticamente

# BEDROCK_MODEL_ID=us.anthropic.claude-3-5-sonnet-20241022-v2:0
# BEDROCK_TIMEOUT_MS=30000
# BEDROCK_MAX_RETRIES=3

# IMPORTANTE: Para usar Bedrock localmente, necesitas:
# 1. Configurar AWS CLI: aws configure
# 2. Agregar permisos de Bedrock a tu usuario IAM
# Ver: aws/README-BEDROCK-SETUP.md para instrucciones detalladas
