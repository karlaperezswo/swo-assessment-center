# Frontend environment variables.
# Variables prefixed with VITE_ are bundled into the client and visible to
# anyone with the deployed JS, so they must NEVER contain secrets. Cognito
# Client IDs and User Pool IDs are public-by-design for SPAs, but treat
# everything else as if it were public too.
#
# Copy this file to .env.development / .env.production and fill in the values
# for your environment.

# Backend API base URL.
VITE_API_URL=http://localhost:4000

# Set to "true" to upload files directly via the local backend (no S3 presigned
# URLs). Useful in dev environments without AWS credentials.
VITE_USE_LOCAL_UPLOAD=true

# Cognito v2 auth.
VITE_AUTH_ENABLED=false
VITE_AWS_REGION=us-east-1
VITE_COGNITO_USER_POOL_ID=
VITE_COGNITO_CLIENT_ID=
VITE_COGNITO_HOSTED_DOMAIN=
